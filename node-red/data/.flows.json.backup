    {
        "id": "5984f54ff4df2ec9",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Enrich Telemetry",
        "func": "let d = msg.payload;\n\nd.roomStatus = d.occupied ? \"Occupied\" : \"Empty\";\nd.lightStatus = d.light ? \"ON\" : \"OFF\";\nd.fanStatus = d.fan ? \"ON\" : \"OFF\";\nd.modeText = d.mode ? d.mode.toUpperCase() : \"UNKNOWN\";\nd.collegeText = d.forceOff ? \"Outside college hours\" : \"Within college hours\";\n\nif (d.afterHoursAlert && d.motion) {\n    d.alertText = \"ALERT: Motion detected after college hours\";\n} else if (d.afterHoursAlert) {\n    d.alertText = \"After-hours monitoring active\";\n} else if (d.temperature >= 35) {\n    d.alertText = \"WARNING: High temperature emergency\";\n} else {\n    d.alertText = \"Normal\";\n}\n\nmsg.payload = d;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 120,
        "wires": [
            [
                "802a5b24d6de93ab",
                "cbf0c9df97eca069",
                "1217929d53d45ff8",
                "0be06d21f02e4872",
                "d79ba0739ca62910",
                "01ede4658b1c35e9",
                "7d8ea3f94c1e9a02",
