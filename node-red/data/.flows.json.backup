        "id": "bcfef89dfcc78679",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "High Temp Warning",
        "func": "if (msg.payload.temperature >= 42) {\n    msg.payload = \"EMERGENCY: Classroom temperature is critically high\";\n} else {\n    msg.payload = \"No critical temperature alert\";\n}\nreturn msg;",
        "outputs": 1,
