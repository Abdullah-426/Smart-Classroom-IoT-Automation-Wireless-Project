        ]
    },
    {
        "id": "ec9800cbd5cad990",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Estimated Energy Saved",
        "func": "let d = msg.payload;\n\nlet lightWatts = 15;\nlet fanWatts = 60;\n\nlet lastTs = context.get(\"lastTs\") || Date.now();\nlet savedWh = context.get(\"savedWh\") || 0;\n\nlet now = Date.now();\nlet dtHours = (now - lastTs) / 3600000;\n\nif (!d.light) {\n    savedWh += lightWatts * dtHours;\n}\n\nif (!d.fan) {\n    savedWh += fanWatts * dtHours;\n}\n\ncontext.set(\"lastTs\", now);\ncontext.set(\"savedWh\", savedWh);\n\nmsg.payload = savedWh.toFixed(2) + \" Wh\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 250,
        "y": 440,
        "wires": [
