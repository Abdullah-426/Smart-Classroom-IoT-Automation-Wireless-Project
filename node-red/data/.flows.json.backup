    {
        "id": "79ca6ac5c19b654e",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "ML Predictor",
        "func": "\nlet d = msg.payload || {};\nlet now = Date.now();\n\nif (typeof d.temperature !== \"number\" || isNaN(d.temperature) || d.temperature === -999) {\n    return [{ payload: \"ML waiting for valid temperature...\" }, null];\n}\n\nlet model = context.get(\"model\") || {\n    history: [],\n    ema: null,\n    forecasts: [],\n    errors: [],\n    lastAssistAt: 0,\n    lastForecastAt: 0\n};\n\n// 1) Evaluate older forecasts whose due time has arrived\nlet dueForecasts = model.forecasts.filter(f => now >= f.due);\nfor (let f of dueForecasts) {\n    model.errors.push(Math.abs(d.temperature - f.pred));\n}\nif (model.errors.length > 20) {\n    model.errors = model.errors.slice(-20);\n}\nmodel.forecasts = model.forecasts.filter(f => now < f.due);\n\n// 2) Update rolling history\nmodel.history.push({\n    t: now,\n    temp: d.temperature,\n    occupied: !!d.occupied,\n    light: Number(d.light || 0),\n    fan: Number(d.fan || 0)\n});\nif (model.history.length > 60) {\n    model.history = model.history.slice(-60);\n}\n\n// 3) Exponential moving average\nif (model.ema === null) model.ema = d.temperature;\nmodel.ema = 0.35 * d.temperature + 0.65 * model.ema;\n\n// 4) Trend model using last 12 points\nlet points = model.history.slice(-12);\nlet ready = points.length >= 6;\nlet trendPred = d.temperature;\nlet slopePerMin = 0;\nlet residualStd = 999;\nlet confidence = 0.25;\n\nif (ready) {\n    let t0 = points[0].t;\n    let n = points.length;\n    let sumx = 0, sumy = 0, sumxy = 0, sumxx = 0;\n\n    for (let p of points) {\n        let x = (p.t - t0) / 60000.0;   // minutes\n        let y = p.temp;\n        sumx += x;\n        sumy += y;\n        sumxy += x * y;\n        sumxx += x * x;\n    }\n\n    let denom = n * sumxx - sumx * sumx;\n    let slope = 0;\n    let intercept = d.temperature;\n\n    if (denom !== 0) {\n        slope = (n * sumxy - sumx * sumy) / denom;\n        intercept = (sumy - slope * sumx) / n;\n    }\n\n    slopePerMin = slope;\n\n    let futureX = ((now + 120000) - t0) / 60000.0;   // 2 minutes ahead\n    trendPred = intercept + slope * futureX;\n\n    let rss = 0;\n    for (let p of points) {\n        let x = (p.t - t0) / 60000.0;\n        let yhat = intercept + slope * x;\n        rss += Math.pow(p.temp - yhat, 2);\n    }\n    residualStd = Math.sqrt(rss / Math.max(1, n - 2));\n\n    let confN = Math.min(1, n / 12);\n    let confFit = 1 / (1 + residualStd);\n    confidence = Math.max(0, Math.min(1, 0.45 * confN + 0.55 * confFit));\n}\n\n// 5) Small feature adjustments\nlet occBoost = d.occupied ? 0.20 : -0.10;\nlet lightBoost = Number(d.light || 0) > 0 ? 0.10 : 0;\nlet fanEffect = Number(d.fan || 0) > 0 ? -0.20 : 0;\n\nlet predicted = 0.60 * trendPred + 0.40 * model.ema + occBoost + lightBoost + fanEffect;\n\n// Clamp unrealistic jumps\npredicted = Math.max(d.temperature - 1.5, Math.min(d.temperature + 3.0, predicted));\npredicted = Number(predicted.toFixed(1));\n\nlet threshold = Number(d.tempThreshold || 28);\nlet stable = Math.abs(slopePerMin) < 0.08;\nlet anomaly = Number(d.fan || 0) > 0 && slopePerMin > 0.12;\n\nlet assist =\n    ready &&\n    !!d.occupied &&\n    !d.forceOff &&\n    confidence >= 0.55 &&\n    predicted > (threshold + 0.3);\n\n// Cooldown so it does not spam commands\nlet cooldownOk = (now - model.lastAssistAt) > 180000;\nif (!cooldownOk) assist = false;\nif (assist) model.lastAssistAt = now;\n\n// Save one forecast every 15s for later accuracy checking\nif (ready && (now - model.lastForecastAt > 15000)) {\n    model.forecasts.push({ due: now + 120000, pred: predicted });\n    if (model.forecasts.length > 20) {\n        model.forecasts = model.forecasts.slice(-20);\n    }\n    model.lastForecastAt = now;\n}\n\nlet mae = null;\nif (model.errors.length) {\n    let total = model.errors.reduce((a, b) => a + b, 0);\n    mae = Number((total / model.errors.length).toFixed(2));\n}\n\ncontext.set(\"model\", model);\n\nlet statusText = assist\n    ? \"Pre-cooling suggested\"\n    : (anomaly ? \"Possible cooling inefficiency\" : (stable ? \"Stable\" : \"Monitoring\"));\n\nlet uiMsg = {\n    payload:\n        \"<b>2-min forecast:</b> \" + predicted + \" °C\" +\n        \"<br><b>Trend:</b> \" + (slopePerMin >= 0 ? \"+\" : \"\") + slopePerMin.toFixed(2) + \" °C/min\" +\n        \"<br><b>Confidence:</b> \" + Math.round(confidence * 100) + \"%\" +\n        (mae !== null ? \"<br><b>Model error (MAE):</b> \" + mae + \" °C\" : \"\") +\n        \"<br><b>Status:</b> \" + statusText,\n    forecast: {\n        predictedTemp: predicted,\n        slopePerMin: Number(slopePerMin.toFixed(2)),\n        confidence: Number(confidence.toFixed(2)),\n        mae: mae,\n        anomaly: anomaly,\n        assist: assist\n    }\n};\n\nlet controlMsg = null;\nif (assist) {\n    controlMsg = {\n        payload: {\n            assist: true,\n            predictedTemp: predicted,\n            confidence: Number(confidence.toFixed(2)),\n            suggestedThreshold: 26.5,\n            reason: \"Predicted temperature is above threshold soon while room is occupied\"\n        }\n    };\n}\n\nreturn [uiMsg, controlMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1390,
        "y": 120,
        "wires": [
            [
                "e79a176961e18050",
                "f61614db00387ea2",
                "f16e4b82a084e86d"
            ],
