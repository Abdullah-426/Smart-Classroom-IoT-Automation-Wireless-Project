    {
        "id": "8d1ded871345ac4f",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Preset Mode",
        "func": "let preset = msg.payload;\n\nif (preset === \"lecture\") {\n    msg.payload = JSON.stringify({\n        mode: \"auto\",\n        tempThreshold: 28.0\n    });\n} else if (preset === \"exam\") {\n    msg.payload = JSON.stringify({\n        mode: \"auto\",\n        tempThreshold: 26.0\n    });\n} else if (preset === \"energy\") {\n    msg.payload = JSON.stringify({\n        mode: \"auto\",\n        tempThreshold: 30.0\n    });\n} else {\n    return null;\n}\n\nreturn msg;",
