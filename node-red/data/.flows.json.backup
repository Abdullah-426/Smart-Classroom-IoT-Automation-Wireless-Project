                "1115c0a1bb20b4ed"
            ]
        ]
    },
    {
        "id": "c3b18bd14e59a0e8",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Occupancy Timer",
        "func": "let d = msg.payload;\n\nlet wasOccupied = context.get(\"wasOccupied\") || false;\nlet occupiedStart = context.get(\"occupiedStart\") || null;\n\nif (d.occupied && !wasOccupied) {\n    occupiedStart = Date.now();\n}\n\nif (!d.occupied) {\n    occupiedStart = null;\n}\n\ncontext.set(\"wasOccupied\", d.occupied);\ncontext.set(\"occupiedStart\", occupiedStart);\n\nif (occupiedStart) {\n    let totalSeconds = Math.floor((Date.now() - occupiedStart) / 1000);\n    let mins = Math.floor(totalSeconds / 60);\n    let secs = totalSeconds % 60;\n    msg.payload = mins + \" min \" + secs + \" sec\";\n} else {\n    msg.payload = \"0 min 0 sec\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 250,
        "y": 360,
        "wires": [
            [
                "41f7f4d82909d1ed"
            ]
        ]
    },
