    {
        "id": "970efc174b7a905b",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Schedule Checker",
        "func": "// Example college hours: 8:00 AM to 6:00 PM\nlet now = new Date();\nlet hour = now.getHours();\n\nlet inCollegeHours = (hour >= 8 && hour < 18);\n\nif (inCollegeHours) {\n    msg.payload = JSON.stringify({\n        forceOff: false,\n        afterHoursAlert: false\n    });\n} else {\n    msg.payload = JSON.stringify({\n        forceOff: true,\n        afterHoursAlert: true\n    });\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 1480,
        "wires": [
