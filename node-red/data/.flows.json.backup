    {
        "id": "e8d9bce2af5cdab0",
        "type": "function",
        "z": "51ea9c70bb53699f",
        "name": "Occupancy Sessions",
        "func": "let d = msg.payload;\n\nlet wasOccupied = context.get(\"wasOccupied\") || false;\nlet occupiedStart = context.get(\"occupiedStart\") || null;\nlet sessions = context.get(\"sessions\") || [];\nlet sessionCount = context.get(\"sessionCount\") || 0;\n\nif (d.occupied && !wasOccupied) {\n    occupiedStart = Date.now();\n}\n\nif (!d.occupied && wasOccupied && occupiedStart) {\n    let durationSeconds = Math.floor((Date.now() - occupiedStart) / 1000);\n    let mins = Math.floor(durationSeconds / 60);\n    let secs = durationSeconds % 60;\n\n    sessionCount += 1;\n    sessions.unshift(`Occupancy Session ${sessionCount}: ${mins} min ${secs} sec`);\n\n    if (sessions.length > 10) {\n        sessions = sessions.slice(0, 10);\n    }\n\n    occupiedStart = null;\n}\n\ncontext.set(\"wasOccupied\", d.occupied);\ncontext.set(\"occupiedStart\", occupiedStart);\ncontext.set(\"sessions\", sessions);\ncontext.set(\"sessionCount\", sessionCount);\n\nmsg.payload = sessions;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 240,
        "y": 400,
        "wires": [
            [
                "585aecca9b12b409"
            ]
        ]
    },
    {
        "id": "585aecca9b12b409",
        "type": "ui-template",
        "z": "51ea9c70bb53699f",
        "group": "a26e1f3bdbd3c5af",
        "page": "",
        "ui": "",
        "name": "Occupancy Sessions",
        "order": 2,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div style=\"padding:8px;\">\n    <div v-if=\"!msg.payload || msg.payload.length === 0\">\n      No completed sessions yet\n    </div>\n\n    <ul v-else style=\"margin:0; padding-left:20px;\">\n      <li v-for=\"(item, index) in msg.payload\" :key=\"index\">\n        {{ item }}\n      </li>\n    </ul>\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 560,
